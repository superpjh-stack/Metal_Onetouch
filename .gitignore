# ====================================================================
# Onetouch AI+MES - .gitignore
# ====================================================================

# --- Environment / secrets ------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
secrets/

# --- Python ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Alembic — keep migrations, ignore generated artifacts
# (no rule needed; alembic outputs go into versions/)

# --- Node.js / pnpm / Next.js ---------------------------------------
node_modules/
.pnp
.pnp.js
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Next.js
.next/
out/
.vercel/
next-env.d.ts

# Build outputs
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/
.playwright-cache/

# Turborepo
.turbo/

# --- Docker / volumes / data ----------------------------------------
volumes/
data/
docker-data/
*.sqlite
*.sqlite3
*.db

# --- IDE / editors --------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json
!.vscode/launch.json.example
*.swp
*.swo
*~
.history/

# JetBrains
*.iml
.idea_modules/

# --- OS -------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Terraform ------------------------------------------------------
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# --- Kubernetes -----------------------------------------------------
kubeconfig
*.kubeconfig

# --- AI / model artifacts -------------------------------------------
*.pkl
*.h5
*.pt
*.pth
*.onnx
*.ckpt
mlruns/
mlartifacts/
.mlflow/

# --- Local development ----------------------------------------------
*.local
*.bak
*.tmp
*.log
logs/
tmp/
temp/

# --- bkit / agent scratch -------------------------------------------
.claude/agent-memory/
.bkit-memory.json
.bkit-cache/
